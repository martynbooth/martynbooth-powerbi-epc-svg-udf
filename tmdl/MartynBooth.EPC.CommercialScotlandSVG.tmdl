createOrReplace

    /// Creates a Scottish commercial EPC SVG rating graphic.
    function 'MartynBooth.EPC.CommercialScotlandSVG' = ```
    (
        score: NUMERIC
    ) =>

    VAR ScoreRounded =
        ROUND ( score, 0 )

    VAR Rating =
        SWITCH (
            TRUE (),
            ScoreRounded < 0, "A+",
            ScoreRounded <= 15, "A",
            ScoreRounded <= 30, "B",
            ScoreRounded <= 45, "C",
            ScoreRounded <= 60, "D",
            ScoreRounded <= 80, "E",
            ScoreRounded <= 100, "F",
            "G"
        )

    VAR MarkerY =
        SWITCH (
            Rating,
            "A+", 58,
            "A", 108,
            "B", 158,
            "C", 208,
            "D", 258,
            "E", 308,
            "F", 358,
            408
        )

    VAR MarkerFill =
        SWITCH (
            Rating,
            "A+", "white",
            "A", "%2300836f",
            "B", "%2330a727",
            "C", "%23a6ce39",
            "D", "%23fff200",
            "E", "%23f6b317",
            "F", "%23f36c21",
            "%23ed1c24"
        )

    VAR MarkerStroke =
        SWITCH (
            Rating,
            "A+", "%2300836f",
            "%23000000"
        )

    VAR LabelText =
        FORMAT ( ScoreRounded, "0" )

    RETURN
        IF (
            ISBLANK ( score ),
            BLANK (),
            "data:image/svg+xml;utf8," &
            "<svg width='840' height='500' viewBox='0 0 840 500' xmlns='http://www.w3.org/2000/svg'>" &

                "<text x='40' y='22' font-family='sans-serif' font-size='18' font-weight='bold' fill='%23000000'>Excellent</text>" &

                "<polygon points='10,58 38,36 145,36 145,80 38,80' fill='white' stroke='%2300836f' stroke-width='4' />" &
                "<text x='95' y='73' text-anchor='middle' font-family='sans-serif' font-size='42' font-weight='bold' fill='white' stroke='%23000000' stroke-width='1'>A+</text>" &
                "<text x='165' y='65' font-family='sans-serif' font-size='18' font-weight='bold' fill='%23000000'>Net Zero Carbon or better</text>" &

                "<rect x='40' y='85' width='195' height='45' fill='%2300836f' />" &
                "<rect x='40' y='135' width='270' height='45' fill='%2330a727' />" &
                "<rect x='40' y='185' width='345' height='45' fill='%23a6ce39' />" &
                "<rect x='40' y='235' width='420' height='45' fill='%23fff200' />" &
                "<rect x='40' y='285' width='495' height='45' fill='%23f6b317' />" &
                "<rect x='40' y='335' width='570' height='45' fill='%23f36c21' />" &
                "<rect x='40' y='385' width='645' height='45' fill='%23ed1c24' />" &

                "<text font-family='sans-serif' font-size='18' font-weight='bold'>" &
                    "<tspan x='50' y='114' fill='white'>(0-15)</tspan>" &
                    "<tspan x='50' y='164' fill='white'>(16-30)</tspan>" &
                    "<tspan x='50' y='214' fill='%23000000'>(31-45)</tspan>" &
                    "<tspan x='50' y='264' fill='%23000000'>(46-60)</tspan>" &
                    "<tspan x='50' y='314' fill='%23000000'>(61-80)</tspan>" &
                    "<tspan x='50' y='364' fill='%23000000'>(81-100)</tspan>" &
                    "<tspan x='50' y='414' fill='%23000000'>(100+)</tspan>" &
                "</text>" &

                "<text font-family='sans-serif' font-size='42' font-weight='bold' fill='white' stroke='%23000000' stroke-width='1'>" &
                    "<tspan x='188' y='121'>A</tspan>" &
                    "<tspan x='263' y='171'>B</tspan>" &
                    "<tspan x='338' y='221'>C</tspan>" &
                    "<tspan x='413' y='271'>D</tspan>" &
                    "<tspan x='488' y='321'>E</tspan>" &
                    "<tspan x='563' y='371'>F</tspan>" &
                    "<tspan x='638' y='421'>G</tspan>" &
                "</text>" &

                "<text x='40' y='462' font-family='sans-serif' font-size='18' font-weight='bold' fill='%23000000'>Very Poor</text>" &

                "<text x='730' y='" &
                    FORMAT ( MarkerY - 35, "0" ) &
                    "' font-family='sans-serif' font-size='16' font-weight='bold' fill='%23000000'>Current</text>" &

                "<polygon points='695,260 715,240 825,240 825,280 715,280' fill='" &
                    MarkerFill &
                    "' stroke='" &
                    MarkerStroke &
                    "' stroke-width='4' transform='translate(0," &
                    FORMAT ( MarkerY - 260, "0" ) &
                    ")' />" &

                "<text x='770' y='" &
                    FORMAT ( MarkerY + 10, "0" ) &
                    "' text-anchor='middle' font-family='sans-serif' font-size='28' font-weight='bold' fill='%23000000'>" &
                    LabelText &
                "</text>" &

            "</svg>"
        )
    ```